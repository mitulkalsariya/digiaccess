# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
.turbo/
coverage/
*.tsbuildinfo

# IDE / OS
.vscode/
.idea/
.claude/
.DS_Store

# Logs (incl. /tmp/api.log etc. accidentally moved into the repo)
*.log

# Environment / secrets — never commit these
.env
.env.local
.env.*.local

# SSH / TLS private keys — never commit
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*

# Generated samples (the script that creates them is committed; the artifact isn't)
sample-finance-report.xlsx

# Editor scratch files
*.swp
*.swo
*~

# Prisma generated client (regenerated on every install)
**/.prisma/

# Extension build artefacts the package script produces
apps/extension/package/
