{
  "name": "@a11y/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "prisma generate && tsc -p tsconfig.test.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo node_modules/.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:validate": "prisma validate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@a11y/shared-types": "workspace:*",
    "@a11y/wcag-rules": "workspace:*",
    "@a11y/axe-mapping": "workspace:*",
    "@aws-sdk/client-kms": "^3.682.0",
    "@axe-core/playwright": "^4.10.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^5.22.0",
    "axe-core": "^4.10.0",
    "bullmq": "^5.21.2",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "openid-client": "^5.7.1",
    "pa11y": "^9.0.0",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.10",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
